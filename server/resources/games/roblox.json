  "buttons": [
    {"label": "Jump", "key": "space"},
    {"label": "Sprint", "key": "shift"},
    {"label": "Crouch", "key": "ctrl"},
    {"label": "Interact", "key": "e"},
    {"label": "Tool", "key": "q"}
  ],
